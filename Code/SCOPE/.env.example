# SCOPE .env template -- copy to .env and fill values. NEVER commit the real .env.
# All keys are read from the environment; no secret is stored in any tracked file.

# HuggingFace (model download)
HUGGINGFACE_TOKEN=

# GitHub push token (checkpointing)
Github_Classic_Token=

# Reproducibility
RANDOM_SEED=20260101

# Judge / answer-extraction. Active tier set by SCOPE_JUDGE_PROVIDER (default gemini).
# No automatic fallback between tiers; keys round-robin within the active tier.
SCOPE_JUDGE_PROVIDER=gemini

# Primary: Google Gemini (gemini-2.5-flash) -- four keys
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=

# Secondary: DeepSeek (deepseek-chat) -- two keys
DEEPSEEK_API_KEY_1=
DEEPSEEK_API_KEY_2=
DEEPSEEK_API_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_JUDGE_MODEL_NAME=deepseek-chat

# Tertiary: Mistral (mistral-small-latest) -- two keys
MISTRAL_API_KEY1=
MISTRAL_API_KEY2=

# Alternative gateway: OpenRouter -- two keys
OPENROUTER_API_KEY_1=
OPENROUTER_API_KEY_2=
OPENROUTER_API_BASE_URL=https://openrouter.ai/api/v1

# The audit config requires these names to be present; SCOPE never calls them.
AWS_ACCESS_KEY=unused-by-scope
AWS_SECRET_KEY=unused-by-scope

# ============================================================
# MIRAGE -- .env.example
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# --- HuggingFace ---
HUGGINGFACE_TOKEN=

# --- DeepSeek (2 keys, round-robin) ---
# Slot d/e generation and the default JSON-repair judge (NOT an evaluation model).
DEEPSEEK_API_KEY_1=
DEEPSEEK_API_KEY_2=
DEEPSEEK_API_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_PRIMARY_MODEL_NAME=deepseek-chat
DEEPSEEK_JUDGE_MODEL_NAME=deepseek-chat

# --- OpenRouter (2 keys, round-robin) ---
# OpenRouter fallback (tertiary for API-3): API-1 (qwen/qwen3-next-80b-a3b-instruct),
# API-2 (amazon/nova-lite-v1), API-3 (google/gemini-2.5-flash), and
# API-4 (mistralai/mistral-medium-3-5). All paid — no :free variants.
OPENROUTER_API_KEY_1=
OPENROUTER_API_KEY_2=
OPENROUTER_API_BASE_URL=https://openrouter.ai/api/v1

# --- Gemini (4 keys, round-robin) ---
# NOT an evaluation model. Optional: selectable JSON-repair judge and slot d/e
# generation fallback only.
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_MODEL_NAME=gemini-2.5-flash-lite

# --- AWS Bedrock (IAM credentials) ---
# API-1 (qwen.qwen3-next-80b-a3b) and API-2 (us.amazon.nova-2-lite-v1:0).
AWS_ACCESS_KEY=
AWS_SECRET_KEY=

# --- Mistral (2 keys, round-robin) ---
# API-4. The eval path passes API_MODELS model_id (mistral-medium-latest) to the
# client; MISTRAL_MODEL_NAME is only the client default for ad-hoc/judge calls.
MISTRAL_API_KEY1=
MISTRAL_API_KEY2=
MISTRAL_MODEL_NAME=mistral-small-latest

# --- MegaLLM (OpenAI-compatible gateway) ---
# API-3 primary (gemini-2.5-flash). Single key. Defaults to https://ai.megallm.io/v1.
MEGALLM_API_Key=
# MEGALLM_API_BASE_URL=https://ai.megallm.io/v1

# --- LinkAPI (OpenAI-compatible gateway) ---
# API-3 secondary (gemini-2.5-flash, geminicheap pricing group). Single key.
# Defaults to https://api.linkapi.ai/v1 (US); HK low-latency: https://hk.linkapi.ai/v1.
GeminiCheap_LinkAPI_Key=
# LINKAPI_API_BASE_URL=https://api.linkapi.ai/v1
